[sub_resource type="GDScript" id="GDScript_gao5a"]
script/source = "@tool
extends TextureRect

@export var base_colour: Color
@export var ridge_colour: Color

func _ready() -> void:
	if material == null:
		return

	material.set_shader_parameter(\"base_colour\", base_colour)
	material.set_shader_parameter(\"ridge_colour\", ridge_colour)
	material.set_shader_parameter(\"offset\", Vector2.ZERO)
	material.set_shader_parameter(\"scale\", 1.0)

	if !Engine.is_editor_hint():
		update_texture_size()
		get_viewport().size_changed.connect(update_texture_size)

func update_texture_size() -> void:
	if texture is NoiseTexture2D:
		var noise_texture: NoiseTexture2D = texture as NoiseTexture2D
		noise_texture.width = int(get_viewport_rect().size.x)
		noise_texture.height = int(get_viewport_rect().size.y)

func _process(_delta: float) -> void:
	if material == null:
		return

	material.set_shader_parameter(\"base_colour\", base_colour)
	material.set_shader_parameter(\"ridge_colour\", ridge_colour)

	if Engine.is_editor_hint():
		return

	var camera: Camera2D = get_viewport().get_camera_2d()
	if camera == null:
		return

	material.set_shader_parameter(
		\"offset\",
		camera.get_screen_center_position() * camera.zoom - size / 2
	)
	material.set_shader_parameter(\"scale\", camera.zoom.x)
"

